---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>The Book Lover — Example</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;700&family=Lora:wght@400;500&family=Cormorant+Garamond:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="topbar">
      <div class="logo">
        <span class="icon">📖</span>
        <span class="wordmark">T.B.L</span>
      </div>
      <nav>
        <a href="#">Home</a>
        <a href="#">About</a>
        <a href="#">Subscribe</a>
        <span class="sns">f</span>
        <span class="sns">t</span>
      </nav>
    </header>

    <section class="hero">
      <div
        class="hero-photo"
        style="background-image: url('https://images.unsplash.com/photo-1507842217343-583bb7270b66?w=2000&q=80');"
      >
      </div>
      <div class="hero-title">
        <h1>THE BOOK LOVER</h1>
        <p>READ ALL ABOUT IT</p>
      </div>
    </section>

    <main class="content">
      <p class="section-label">All Posts</p>
      <div class="grid">
        {
          posts.map((p) => (
            <article class={`card ${p.tall ? "tall" : "short"}`}>
              <div
                class="card-photo"
                style={`background-image: url('${p.image}');`}
              />
              <div class="card-body">
                <div class="avatar-row">
                  <span class="avatar" />
                  <span class="avatar-meta">
                    {p.date} · {p.readTime}
                  </span>
                  <span class="dots">⋮</span>
                </div>
                <h3>{p.title}</h3>
                <p class="excerpt">{p.excerpt}</p>
                <div class="reactions">
                  <span>{p.views} views</span>
                  <span>{p.comments} comments</span>
                  <span class="heart">♡ {p.likes}</span>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </main>

    <footer class="footer">
      <div class="foot-inner">
        <h4>Subscribe here to get my latest posts</h4>
        <form>
          <label>Enter your email here *</label>
          <div class="row">
            <input type="email" />
            <button type="button">Join</button>
          </div>
        </form>
        <p class="copy">
          © 2025 by The Book Lover. Proudly created as a design experiment.
        </p>
      </div>
    </footer>

    <style is:global>
      :root {
        --cream: #efece6;
        --paper: #ffffff;
        --ink: #1a1a1a;
        --muted: #8a8a8a;
        --line: #eadfd4;
        --gold: #a88b4a;
      }
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        background: var(--cream);
        color: var(--ink);
        font-family: "Lora", "Playfair Display", Georgia, serif;
        -webkit-font-smoothing: antialiased;
      }
      a {
        color: inherit;
        text-decoration: none;
      }
      img {
        display: block;
        max-width: 100%;
      }

      /* topbar */
      .topbar {
        background: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 40px;
        position: relative;
        z-index: 3;
      }
      .logo {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .logo .icon {
        color: var(--gold);
        font-size: 18px;
      }
      .logo .wordmark {
        font-family: "Cormorant Garamond", serif;
        font-weight: 600;
        font-size: 20px;
        letter-spacing: 0.1em;
      }
      .topbar nav {
        display: flex;
        gap: 28px;
        align-items: center;
        font-size: 13px;
      }
      .topbar .sns {
        font-size: 12px;
        color: var(--ink);
      }

      /* hero */
      .hero {
        position: relative;
        height: 360px;
        overflow: hidden;
      }
      .hero-photo {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        filter: brightness(0.92);
      }
      .hero-title {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: #fff;
        padding: 28px 64px;
        text-align: center;
      }
      .hero-title h1 {
        font-family: "Cormorant Garamond", serif;
        font-weight: 500;
        font-size: 34px;
        letter-spacing: 0.25em;
      }
      .hero-title p {
        font-family: "Cormorant Garamond", serif;
        font-size: 12px;
        letter-spacing: 0.35em;
        margin-top: 8px;
        color: var(--muted);
      }

      /* content */
      .content {
        max-width: 860px;
        margin: 0 auto;
        padding: 60px 24px 80px;
      }
      .section-label {
        font-size: 12px;
        color: var(--muted);
        margin-bottom: 24px;
      }
      .grid {
        column-count: 2;
        column-gap: 32px;
      }
      .card {
        background: #fff;
        margin: 0 0 32px;
        break-inside: avoid;
        display: inline-block;
        width: 100%;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
      }
      .card-photo {
        width: 100%;
        background-size: cover;
        background-position: center;
        background-color: #d8d1c8;
      }
      .card.tall .card-photo {
        height: 280px;
      }
      .card.short .card-photo {
        height: 180px;
      }
      .card-body {
        padding: 18px 20px 20px;
      }
      .avatar-row {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 10px;
      }
      .avatar {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: #e6e0d6;
        display: inline-block;
      }
      .avatar-meta {
        font-size: 11px;
        color: var(--muted);
        flex: 1;
      }
      .dots {
        color: var(--muted);
      }
      .card h3 {
        font-family: "Playfair Display", serif;
        font-weight: 500;
        font-size: 19px;
        line-height: 1.3;
        margin-bottom: 10px;
      }
      .card .excerpt {
        font-size: 13px;
        color: #555;
        line-height: 1.55;
        font-family: "Lora", serif;
      }
      .card .reactions {
        margin-top: 14px;
        display: flex;
        gap: 14px;
        font-size: 11px;
        color: var(--muted);
      }
      .heart {
        color: #d14a4a;
      }

      /* footer */
      .footer {
        background: #111;
        color: #fff;
        padding: 36px 24px;
      }
      .foot-inner {
        max-width: 860px;
        margin: 0 auto;
      }
      .foot-inner h4 {
        font-family: "Playfair Display", serif;
        font-weight: 500;
        font-size: 18px;
        margin-bottom: 18px;
      }
      .foot-inner label {
        display: block;
        font-size: 11px;
        color: #bbb;
        margin-bottom: 6px;
      }
      .foot-inner .row {
        display: flex;
        gap: 12px;
        align-items: stretch;
      }
      .foot-inner input {
        flex: 1;
        background: transparent;
        border: none;
        border-bottom: 1px solid #666;
        color: #fff;
        padding: 8px 2px;
        outline: none;
        font-family: inherit;
        font-size: 14px;
      }
      .foot-inner button {
        background: transparent;
        border: 1px solid #fff;
        color: #fff;
        padding: 8px 28px;
        cursor: pointer;
        letter-spacing: 0.1em;
        font-family: inherit;
      }
      .copy {
        margin-top: 26px;
        font-size: 11px;
        color: #888;
        text-align: center;
      }

      @media (max-width: 720px) {
        .grid {
          column-count: 1;
        }
        .hero {
          height: 260px;
        }
        .hero-title {
          padding: 18px 32px;
        }
        .hero-title h1 {
          font-size: 24px;
        }
        .topbar {
          padding: 14px 18px;
        }
        .topbar nav {
          gap: 16px;
        }
      }
    </style>
  </body>
</html>
